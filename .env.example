# ===========================================
# THE ARGENT ORDER - Environment Variables
# ===========================================

# ─────────────────────────────────────────────
# SUPABASE (Required)
# ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# DISCORD BOT (Required for bot)
# ─────────────────────────────────────────────
# Get these from: https://discord.com/developers/applications

DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_GUILD_ID=your-server-id

# ─────────────────────────────────────────────
# PORTAL URL (Required)
# ─────────────────────────────────────────────
# Your deployed portal URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://portal.theargentorder.com
PORTAL_URL=https://portal.theargentorder.com

# ─────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────

# OpenAI (for AI features - leave blank for now)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vercel (auto-set on deploy)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────
# RESEND EMAIL (Required for welcome emails)
# ─────────────────────────────────────────────
# Get from: https://resend.com
# Sign up, add API key, and get your Discord invite link ready
RESEND_API_KEY=your-resend-api-key
DISCORD_INVITE_URL=https://discord.gg/your-invite-link
