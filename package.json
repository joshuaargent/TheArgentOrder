{
  "name": "@argent-order/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "The Argent Order - Catholic Formation Operating System for Builders",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@argent-order/web",
    "dev:web": "npm run dev --workspace=@argent-order/web",
    "dev:bot": "npm run dev --workspace=@argent-order/bot",
    "build": "npm run build --workspace=@argent-order/web",
    "build:web": "npm run build --workspace=@argent-order/web",
    "build:bot": "npm run build --workspace=@argent-order/bot",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
