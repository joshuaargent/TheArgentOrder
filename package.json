{
  "name": "@argent-order/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "The Argent Order - Catholic Formation Operating System for Builders",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:web": "pnpm --filter @argent-order/web dev",
    "dev:bot": "pnpm --filter @argent-order/bot dev",
    "build": "pnpm --filter @argent-order/web build && pnpm --filter @argent-order/bot build",
    "build:web": "pnpm --filter @argent-order/web build",
    "build:bot": "pnpm --filter @argent-order/bot build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "type-check": "pnpm -r type-check",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @argent-order/infra exec supabase db push",
    "db:generate": "pnpm --filter @argent-order/web exec supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/types/src/database.types.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
