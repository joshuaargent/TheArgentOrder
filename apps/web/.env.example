# ===========================================
# SUPABASE - Database & Authentication
# ===========================================
# Find these in: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# DISCORD - OAuth
# ===========================================
# Find in: Discord Developer Portal → Your App → General Information

DISCORD_CLIENT_ID=your-discord-application-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-application-id

# ===========================================
# RESEND - Welcome Emails with Discord Links
# ===========================================
# Get from: https://resend.com
# Create Discord invite with unlimited uses, copy the link
# 
# IMPORTANT: Free tier can only send to your account email.
# For production, verify a domain at resend.com/domains

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=your-account-email@outlook.com
DISCORD_INVITE_URL=https://discord.gg/your-invite-link

# ===========================================
# APP URL
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
