# ===========================================
# SUPABASE - Database & Authentication
# ===========================================
# Find these in: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# DISCORD - OAuth & Bot
# ===========================================
# Find OAuth creds in: Discord Developer Portal → General Information
# Find Bot token in: Discord Developer Portal → Bot → Reset Token

DISCORD_CLIENT_ID=your-discord-application-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-application-id
DISCORD_TOKEN=your-discord-bot-token

# ===========================================
# CONVERTKIT - Newsletter & Email Capture
# ===========================================
# Find these in: ConvertKit → Settings → Advanced → API
# API Secret: Settings → Advanced → API → API Secret
# Form ID: Create a form and get its ID

CONVERTKIT_API_SECRET=your-convertkit-api-secret
CONVERTKIT_FORM_ID=your-convertkit-form-id

# ===========================================
# APP URLs - For redirects and SEO
# ===========================================
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (uncomment and fill in for deployment)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
