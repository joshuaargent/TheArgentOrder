# ===========================================
# DISCORD BOT - The Argent Order
# ===========================================

DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_GUILD_ID=your-server-id

# ===========================================
# SUPABASE
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# CHANNEL IDs (optional - for notifications)
# ===========================================
# After running /setup, find these IDs:
# 1. Enable Developer Mode in Discord (User Settings → Advanced)
# 2. Right-click channels → "Copy Channel ID"
# Or leave blank - notifications just won't post
PRAYER_CHANNEL_ID=
TESTIMONY_CHANNEL_ID=
EVENTS_CHANNEL_ID=

# ===========================================
# PORTAL URL
# ===========================================
PORTAL_URL=https://your-app.vercel.app
